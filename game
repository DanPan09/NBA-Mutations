        function getRandomAttribute() {
            const primaryPool = ["Finishing", "Shooting", "Defense"];
            const rarePool = ["Playmaking", "Handles", "Body", "Speed", "IQ", "Rebounding"];
            return Math.random() < 0.55 
                ? primaryPool[Math.floor(Math.random() * primaryPool.length)]
                : rarePool[Math.floor(Math.random() * rarePool.length)];
        }

        const positions = ["PG", "SG", "SF", "PF", "C", "6TH"];
        let roster = { "PG": null, "SG": null, "SF": null, "PF": null, "C": null, "6TH": null };
        let generatedRowData = [];
        let SelectedSwitcherooPlayer = null;
        let rerollsRemaining = 3;
        let dragSourceIndex = null;
        let activeCoversState = { 0: true, 1: true, 2: true };

        function toggleSettingsMenu() {
            // Close help overlay if it's open to prevent overlay overlaps
            document.getElementById('help-overlay').style.display = 'none';
            
            const overlay = document.getElementById('settings-overlay');
            const wrapper = document.getElementById('game-wrapper');
            if (overlay.style.display === 'flex') {
                overlay.style.display = 'none';
                wrapper.classList.remove('blurred');
            } else {
                overlay.style.display = 'flex';
                wrapper.classList.add('blurred');
            }
        }

        function toggleHelpMenu() {
            // Close settings overlay if it's open
            document.getElementById('settings-overlay').style.display = 'none';

            const overlay = document.getElementById('help-overlay');
            const wrapper = document.getElementById('game-wrapper');
            if (overlay.style.display === 'flex') {
                overlay.style.display = 'none';
                wrapper.classList.remove('blurred');
            } else {
                overlay.style.display = 'flex';
                wrapper.classList.add('blurred');
            }
        }

        function toggleThemeLayout(isLight) {
            if (isLight) {
                document.body.classList.add('light-theme');
            } else {
                document.body.classList.remove('light-theme');
            }
        }

        function getRosteredPlayerNames() {
            return Object.values(roster).filter(val => val !== null).map(val => val.mainPlayer);
        }

        function getValidPlayer1Selection() {
            const rosteredNames = getRosteredPlayerNames();
            const availablePool = players.filter(p => !rosteredNames.includes(p.name));
            if (availablePool.length === 0) return players[Math.floor(Math.random() * players.length)];
            return availablePool[Math.floor(Math.random() * availablePool.length)];
        }

        function getValidPlayer2Selection(player1) {
            const filtered = players.filter(p => p.name !== player1.name);
            return filtered[Math.floor(Math.random() * filtered.length)];
        }

        function initiateNewDraftGame() {
            rerollsRemaining = 3;
            activeCoversState = { 0: true, 1: true, 2: true };
            document.getElementById('rerollCount').innerText = rerollsRemaining;
            document.getElementById('hud-counter').style.display = 'block';
            document.getElementById('masterSpinBtn').disabled = false;
            document.getElementById('help-trigger-btn').style.display = 'none'; // Only accessible on home menu
            switchScreen('spin-screen');
            buildSpinRows();
        }

        function goToMainMenu() {
            document.getElementById('hud-counter').style.display = 'none';
            document.getElementById('help-trigger-btn').style.display = 'block';
            switchScreen('menu-screen');
        }

        function cancelSelectionAndReturn() {
            SelectedSwitcherooPlayer = null;
            document.getElementById('hud-counter').style.display = 'block';
            switchScreen('spin-screen');
        }

        function resetGame() {
            roster = { "PG": null, "SG": null, "SF": null, "PF": null, "C": null, "6TH": null };
            document.getElementById('gameOverControls').style.display = 'none';
            initiateNewDraftGame();
        }

        function switchScreen(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
        }

        function createPlayerHTML(player) {
            return `<div class="player-name-display" style="background-color: ${player.bg}; color: ${player.text};">${player.name}</div>`;
        }

        function updateRerollDisplay() {
            document.getElementById('rerollCount').innerText = rerollsRemaining;
        }

        function buildSpinRows() {
            const matrix = document.getElementById('spinMatrix');
            matrix.innerHTML = '';
            generatedRowData = [];

            for (let i = 0; i < 3; i++) {
                generatedRowData.push({ p1: players[0], p2: players[1], attr: "Shooting" });

                const blockContainer = document.createElement('div');
                blockContainer.className = 'row-container-block';

                const row = document.createElement('div');
                row.className = 'spin-row';
                row.id = `row-${i}`;
                row.innerHTML = `
                    <div class="card-container" id="container-${i}-p1">
                        <div class="card-cover" id="cover-${i}-p1" style="display: ${activeCoversState[i] ? 'flex' : 'none'};">Player 1</div>
                        <div class="card-header">Player 1</div>
                        <div class="card-slot" id="row-${i}-p1"></div>
                        <div class="reroll-overlay"><button class="reroll-btn" onclick="executeSingleReroll(${i}, 'p1')">Reroll</button></div>
                    </div>
                    <div class="row-connector">With</div>
                    <div class="card-container" id="container-${i}-p2">
                        <div class="card-cover" id="cover-${i}-p2" style="display: ${activeCoversState[i] ? 'flex' : 'none'};">Player 2</div>
                        <div class="card-header">Player 2</div>
                        <div class="card-slot" id="row-${i}-p2"></div>
                        <div class="reroll-overlay"><button class="reroll-btn" onclick="executeSingleReroll(${i}, 'p2')">Reroll</button></div>
                    </div>
                    <div class="row-connector">'s</div>
                    <div class="card-container" id="container-${i}-attr">
                        <div class="card-cover" id="cover-${i}-attr" style="display: ${activeCoversState[i] ? 'flex' : 'none'};">Attribute</div>
                        <div class="card-header">Attribute</div>
                        <div class="card-slot" id="row-${i}-attr"></div>
                        <div class="reroll-overlay"><button class="reroll-btn" onclick="executeSingleReroll(${i}, 'attr')">Reroll</button></div>
                    </div>
                `;

                const sideChooseBtn = document.createElement('button');
                sideChooseBtn.className = 'choose-btn';
                sideChooseBtn.id = `choose-btn-${i}`;
                sideChooseBtn.innerText = "Pick";
                sideChooseBtn.onclick = () => choosePlayer(i);
                
                if (!activeCoversState[i]) {
                     sideChooseBtn.classList.add('ready');
                }

                blockContainer.appendChild(row);
                blockContainer.appendChild(sideChooseBtn);
                matrix.appendChild(blockContainer);

                if(!activeCoversState[i]) {
                     document.getElementById(`row-${i}-p1`).innerHTML = createPlayerHTML(generatedRowData[i].p1);
                     document.getElementById(`row-${i}-p2`).innerHTML = createPlayerHTML(generatedRowData[i].p2);
                     document.getElementById(`row-${i}-attr`).innerHTML = `<div class="attribute-display">${generatedRowData[i].attr}</div>`;
                     document.getElementById(`container-${i}-p1`).classList.add('allow-hover');
                     document.getElementById(`container-${i}-p2`).classList.add('allow-hover');
                     document.getElementById(`container-${i}-attr`).classList.add('allow-hover');
                }
            }
        }

        async function spinRowsSequentially() {
            document.getElementById('masterSpinBtn').disabled = true;
            document.querySelectorAll('.choose-btn').forEach(btn => btn.classList.remove('ready'));
            document.querySelectorAll('.card-container').forEach(c => c.classList.remove('allow-hover'));

            for(let i=0; i<3; i++) {
                activeCoversState[i] = false;
                document.getElementById(`cover-${i}-p1`).style.display = 'none';
                document.getElementById(`cover-${i}-p2`).style.display = 'none';
                document.getElementById(`cover-${i}-attr`).style.display = 'none';
                await Promise.all([runSlotSpinAnimation(i, 'p1'), runSlotSpinAnimation(i, 'p2'), runSlotSpinAnimation(i, 'attr')]);
            }

            document.querySelectorAll('.choose-btn').forEach(btn => btn.classList.add('ready'));
            document.querySelectorAll('.card-container').forEach(c => c.classList.add('allow-hover'));
        }

        function runSlotSpinAnimation(rowIndex, targetType) {
            return new Promise((resolve) => {
                let totalDuration = 1400; 
                let elapsedTime = 0;
                let currentInterval = 20; 
                
                const slot = document.getElementById(`row-${rowIndex}-${targetType}`);
                slot.classList.add('spinning-glow');

                function nextTick() {
                    if (targetType === 'p1' || targetType === 'p2') {
                        slot.innerHTML = createPlayerHTML(players[Math.floor(Math.random() * players.length)]);
                    } else {
                        slot.innerHTML = `<div class="attribute-display">${getRandomAttribute()}</div>`;
                    }

                    elapsedTime += currentInterval;
                    
                    let progress = elapsedTime / totalDuration;
                    if (progress < 0.65) {
                        currentInterval = 20; 
                    } else {
                        currentInterval = 20 + Math.pow((progress - 0.65) / 0.35, 2.5) * 120;
                    }

                    if (elapsedTime >= totalDuration) {
                        slot.classList.remove('spinning-glow');

                        if (targetType === 'p1') {
                            generatedRowData[rowIndex].p1 = getValidPlayer1Selection();
                            slot.innerHTML = createPlayerHTML(generatedRowData[rowIndex].p1);
                        } else if (targetType === 'p2') {
                            generatedRowData[rowIndex].p2 = getValidPlayer2Selection(generatedRowData[rowIndex].p1);
                            slot.innerHTML = createPlayerHTML(generatedRowData[rowIndex].p2);
                        } else {
                            generatedRowData[rowIndex].attr = getRandomAttribute();
                            slot.innerHTML = `<div class="attribute-display">${generatedRowData[rowIndex].attr}</div>`;
                        }
                        resolve();
                    } else {
                        setTimeout(nextTick, currentInterval);
                    }
                }

                setTimeout(nextTick, currentInterval);
            });
        }

        function executeSingleReroll(rowIndex, targetType) {
            if (rerollsRemaining <= 0) {
                alert("No Rerolls Left!");
                return;
            }

            const previousValue = (targetType === 'attr') 
                ? generatedRowData[rowIndex].attr 
                : generatedRowData[rowIndex][targetType].name;

            rerollsRemaining--;
            updateRerollDisplay();

            document.querySelectorAll('.card-container').forEach(c => c.classList.remove('allow-hover'));
            document.querySelectorAll('.choose-btn').forEach(btn => btn.classList.remove('ready'));

            const slotElement = document.getElementById(`row-${rowIndex}-${targetType}`);
            slotElement.classList.add('spinning-glow');

            let totalDuration = 1400;
            let elapsedTime = 0;
            let currentInterval = 20;

            function nextRerollTick() {
                if (targetType === 'p1' || targetType === 'p2') {
                    slotElement.innerHTML = createPlayerHTML(players[Math.floor(Math.random() * players.length)]);
                } else {
                    slotElement.innerHTML = `<div class="attribute-display">${getRandomAttribute()}</div>`;
                }

                elapsedTime += currentInterval;
                let progress = elapsedTime / totalDuration;
                if (progress < 0.65) {
                    currentInterval = 20;
                } else {
                    currentInterval = 20 + Math.pow((progress - 0.65) / 0.35, 2.5) * 120;
                }

                if (elapsedTime >= totalDuration) {
                    slotElement.classList.remove('spinning-glow');

                    if (targetType === 'p1') {
                        let finalP1;
                        do {
                            finalP1 = getValidPlayer1Selection();
                        } while (finalP1.name === previousValue || finalP1.name === generatedRowData[rowIndex].p2.name);
                        
                        generatedRowData[rowIndex].p1 = finalP1;
                        slotElement.innerHTML = createPlayerHTML(finalP1);
                    } else if (targetType === 'p2') {
                        let finalP2;
                        do {
                            finalP2 = getValidPlayer2Selection(generatedRowData[rowIndex].p1);
                        } while (finalP2.name === previousValue);
                        
                        generatedRowData[rowIndex].p2 = finalP2;
                        slotElement.innerHTML = createPlayerHTML(finalP2);
                    } else {
                        let finalAttr;
                        do {
                            finalAttr = getRandomAttribute();
                        } while (finalAttr === previousValue);
                        
                        generatedRowData[rowIndex].attr = finalAttr;
                        slotElement.innerHTML = `<div class="attribute-display">${finalAttr}</div>`;
                    }

                    document.querySelectorAll('.card-container').forEach(c => c.classList.add('allow-hover'));
                    document.querySelectorAll('.choose-btn').forEach(btn => btn.classList.add('ready'));
                } else {
                    setTimeout(nextRerollTick, currentInterval);
                }
            }

            setTimeout(nextRerollTick, currentInterval);
        }

        function choosePlayer(rowIndex) {
            const selection = generatedRowData[rowIndex];
            SelectedSwitcherooPlayer = {
                mainPlayer: selection.p1.name,
                subTrait: `(${selection.p2.name}'s ${selection.attr})`,
                bg: selection.p1.bg,
                text: selection.p1.text
            };
            
            document.getElementById('hud-counter').style.display = 'none';
            switchScreen('roster-screen');
            renderRosterSelectionLayout();
        }

        function renderRosterSelectionLayout() {
            const container = document.getElementById('rosterContainer');
            container.innerHTML = '';

            const isFull = positions.every(p => roster[p] !== null);

            if (SelectedSwitcherooPlayer) {
                document.getElementById('rosterTitle').innerText = "Assign Position";
                document.getElementById('currentPlayerBanner').innerHTML = `
                    Placing: <span>${SelectedSwitcherooPlayer.mainPlayer} ${SelectedSwitcherooPlayer.subTrait}</span>
                    <button class="back-selection-btn" onclick="cancelSelectionAndReturn()">Back</button>
                `;
            } else {
                document.getElementById('rosterTitle').innerText = isFull ? "Roster Complete" : "Your Lineup Layout";
                document.getElementById('currentPlayerBanner').innerHTML = isFull ? `<span>Press or drag boxes to Swap positions</span>` : `Waiting for next pick...`;
            }

            positions.forEach((pos, idx) => {
                const row = document.createElement('div');
                row.className = 'roster-slot-row';
                row.dataset.index = idx;

                row.addEventListener('dragover', handleDragOver);
                row.addEventListener('dragleave', handleDragLeave);
                row.addEventListener('drop', handleDrop);

                if (roster[pos]) {
                    row.draggable = true;
                    row.addEventListener('dragstart', handleDragStart);
                    row.addEventListener('dragend', handleDragEnd);
                }

                const posLabel = document.createElement('div');
                posLabel.className = 'position-label';
                posLabel.innerText = pos;

                const posBox = document.createElement('div');
                posBox.className = 'position-box';

                if (roster[pos]) {
                    posBox.classList.add('draggable-filled');
                    posBox.style.backgroundColor = roster[pos].bg;
                    posBox.style.color = roster[pos].text;
                    posBox.style.borderColor = "transparent";
                    
                    posBox.innerHTML = `
                        <div class="display-main-name">${roster[pos].mainPlayer}</div>
                        <div class="display-sub-trait">${roster[pos].subTrait}</div>
                    `;
                } else {
                    posBox.innerHTML = `<div class="display-main-name">— Empty —</div>`;
                    posBox.classList.add('empty');
                    
                    if (SelectedSwitcherooPlayer) {
                        posBox.classList.add('selectable');
                        posBox.onclick = () => assignPlayerToPosition(pos);
                    }
                }

                row.appendChild(posLabel);
                row.appendChild(posBox);
                container.appendChild(row);
            });
        }

        function handleDragStart(e) {
            dragSourceIndex = this.dataset.index;
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        }

        function handleDragOver(e) {
            if (e.preventDefault) e.preventDefault();
            this.classList.add('drag-over');
            return false;
        }

        function handleDragLeave() {
            this.classList.remove('drag-over');
        }

        function handleDrop(e) {
            if (e.stopPropagation) e.stopPropagation();
            this.classList.remove('drag-over');
            
            const targetIndex = this.dataset.index;
            if (dragSourceIndex !== null && dragSourceIndex !== targetIndex) {
                const sourcePosKey = positions[dragSourceIndex];
                const targetPosKey = positions[targetIndex];

                let temp = roster[sourcePosKey];
                roster[sourcePosKey] = roster[targetPosKey];
                roster[targetPosKey] = temp;

                renderRosterSelectionLayout();
            }
            return false;
        }

        function handleDragEnd() {
            this.classList.remove('dragging');
            document.querySelectorAll('.roster-slot-row').forEach(row => {
                row.classList.remove('dragging');
                row.classList.remove('drag-over');
            });
            dragSourceIndex = null;
        }

        function assignPlayerToPosition(pos) {
            if (!SelectedSwitcherooPlayer) return;

            roster[pos] = SelectedSwitcherooPlayer;
            SelectedSwitcherooPlayer = null;

            const isFull = positions.every(p => roster[p] !== null);

            if (isFull) {
                renderRosterSelectionLayout();
                document.getElementById('gameOverControls').style.display = 'flex';
                document.getElementById('hud-counter').style.display = 'none';
            } else {
                activeCoversState = { 0: true, 1: true, 2: true }; 
                document.getElementById('hud-counter').style.display = 'block';
                switchScreen('spin-screen');
                buildSpinRows(); 
                document.getElementById('masterSpinBtn').disabled = false;
            }
        }
    </script>
</body>
</html>
